{
  "_comment": "Config-driven inputs for generate_synthetic_data.py. Edit 'global' to change the time period. Add entries to 'scenarios' to bring in more use cases additively -- each enabled scenario's rows are generated independently (own RNG seed, own tenants/tools/storylines) and appended into the same shared CSVs, so adding a scenario grows the dataset without altering the numbers already produced by existing scenarios.",

  "global": {
    "random_seed": 42,
    "start_date": "2026-06-01",
    "end_date": "2026-06-30"
  },

  "scenarios": [
    {
      "id": "retail_support",
      "enabled": true,
      "description": "Original demo scenario -- retail order support & returns assistant. Values below are the exact constants the generator used before it was made config-driven, so the default run reproduces the published README headline numbers and the incident/release IDs referenced in docs/ and training/.",
      "use_case": "order_support_returns_assistant",
      "use_case_label": "Order Support & Returns Assistant",
      "business_unit": "Retail Customer Care",
      "ml_app": "retail-support-agent",
      "service": "support-agent-orchestrator",
      "env": "production",
      "version": "2.4.1",

      "tenants": ["brand_a", "brand_b", "brand_c"],
      "channels": { "web_chat": 0.55, "mobile_app": 0.35, "ivr_handoff": 0.10 },

      "primary_model": { "provider": "openai", "model": "gpt-4o-mini", "model_version": "2026-05", "rate_in_per_1k": 0.00015, "rate_out_per_1k": 0.0006 },
      "fallback_model": { "provider": "anthropic", "model": "claude-3-5-haiku", "model_version": "2026-05", "rate_in_per_1k": 0.0008, "rate_out_per_1k": 0.0040 },

      "retrievers": [
        ["returns_policy_kb", "policy_lookup"],
        ["order_history_index", "order_lookup"],
        ["faq_kb", "faq_lookup"]
      ],

      "tools": [
        { "name": "order_lookup", "version": "1.3.0", "action_type": "read", "read_or_write": "read", "risk_class": "low" },
        { "name": "shipping_status", "version": "1.1.0", "action_type": "read", "read_or_write": "read", "risk_class": "low" },
        { "name": "refund_issue", "version": "2.0.0", "action_type": "write", "read_or_write": "write", "risk_class": "high" },
        { "name": "loyalty_credit", "version": "1.4.0", "action_type": "write", "read_or_write": "write", "risk_class": "medium" },
        { "name": "address_update", "version": "1.0.2", "action_type": "write", "read_or_write": "write", "risk_class": "high" }
      ],
      "tool_cost_by_risk": { "low": 0.0015, "medium": 0.012, "high": 0.035 },

      "guardrails": {
        "injection_scan": { "name": "input_prompt_injection_scan", "version": "3.1", "evaluator": "injection_classifier_v3", "threshold": 0.75, "background_rate": 0.008, "catch_rate": 0.92 },
        "pii_scan": { "name": "output_pii_egress_scan", "version": "2.2", "evaluator": "dlp_scanner_v2", "threshold": 0.8, "rate": 0.004 },
        "toxicity_scan": { "name": "output_toxicity_check", "version": "1.5", "evaluator": "toxicity_classifier_v1", "threshold": 0.6, "rate": 0.002 },
        "approval_policy": { "name": "high_risk_action_approval", "version": "1.0", "evaluator": "policy_engine" }
      },

      "volume": { "base_daily": 140, "growth_per_day": 2, "weekend_dip_factor": 0.7, "jitter": 15 },
      "escalation_rate": { "normal": 0.06, "spike": 0.11 },

      "storylines": {
        "release_regression": {
          "enabled": true, "day_start": 7, "day_end": 8,
          "from_version": "v14", "to_version": "v15",
          "release_event_id": "REL-2026-0608", "rollback_event_id": "REL-2026-0609",
          "release_golden_set_accuracy_pct": 79.2, "release_regression_pass_rate_pct": 81.5,
          "rollback_golden_set_accuracy_pct": 91.8, "rollback_regression_pass_rate_pct": 97.4,
          "release_notes": "Prompt v15 rolled out to improve refund-policy phrasing; canary evaluation flagged a groundedness/citation-accuracy regression within 4 hours of rollout.",
          "rollback_notes": "Rolled back to v14 after golden-set accuracy and regression pass rate both breached release-gate thresholds; v15 held for revision before re-attempting rollout."
        },
        "injection_cluster": {
          "enabled": true, "day_start": 11, "day_end": 12, "rate": 0.18,
          "incident_id": "INC-2026-0611", "severity": "Sev2",
          "detected_offset": { "days": 11, "hours": 14, "minutes": 20 },
          "resolved_offset": { "days": 12, "hours": 9, "minutes": 5 },
          "root_cause_category": "prompt_injection_policy_bypass",
          "detection_source": "guardrail_anomaly_monitor",
          "mitigation": "Tightened injection_classifier_v3 threshold from 0.75 to 0.68; added secondary human-review gate on refund_issue tool for flagged sessions."
        },
        "rate_limit_spike": {
          "enabled": true, "day_start": 20, "day_end": 21,
          "volume_multiplier": 2.3, "rate_limit_prob": 0.30, "fallback_prob": 0.75,
          "incident_id": "INC-2026-0621", "severity": "Sev1",
          "detected_offset": { "days": 20, "hours": 10, "minutes": 5 },
          "resolved_offset": { "days": 21, "hours": 6, "minutes": 40 },
          "root_cause_category": "provider_rate_limit_cascade",
          "detection_source": "cost_and_latency_anomaly_monitor",
          "affected_workflows_note": "~35% of workflows on days 21-22",
          "mitigation": "Added request queuing + provider fallback pre-routing ahead of known promo windows; raised primary provider quota tier."
        }
      }
    },

    {
      "id": "banking_card_disputes",
      "enabled": false,
      "description": "Example second use case (disabled by default) showing the additive pattern -- a Financial Services / Banking scenario alongside the Retail one. Enable it (set enabled: true) to see both use cases combine in the same dashboard run. Numbers are illustrative starting points, tune freely.",
      "use_case": "card_dispute_fraud_triage_assistant",
      "use_case_label": "Card Dispute & Fraud Triage Assistant",
      "business_unit": "Retail Banking Operations",
      "ml_app": "cards-dispute-agent",
      "service": "dispute-triage-orchestrator",
      "env": "production",
      "version": "1.2.0",

      "tenants": ["retail_bank", "business_bank"],
      "channels": { "web_portal": 0.50, "mobile_app": 0.40, "branch_assist": 0.10 },

      "primary_model": { "provider": "openai", "model": "gpt-4o-mini", "model_version": "2026-05", "rate_in_per_1k": 0.00015, "rate_out_per_1k": 0.0006 },
      "fallback_model": { "provider": "anthropic", "model": "claude-3-5-haiku", "model_version": "2026-05", "rate_in_per_1k": 0.0008, "rate_out_per_1k": 0.0040 },

      "retrievers": [
        ["dispute_policy_kb", "policy_lookup"],
        ["transaction_history_index", "txn_lookup"],
        ["regulation_kb", "reg_lookup"]
      ],

      "tools": [
        { "name": "transaction_lookup", "version": "1.2.0", "action_type": "read", "read_or_write": "read", "risk_class": "low" },
        { "name": "dispute_status", "version": "1.0.1", "action_type": "read", "read_or_write": "read", "risk_class": "low" },
        { "name": "chargeback_file", "version": "1.1.0", "action_type": "write", "read_or_write": "write", "risk_class": "high" },
        { "name": "provisional_credit", "version": "1.0.0", "action_type": "write", "read_or_write": "write", "risk_class": "medium" },
        { "name": "card_block", "version": "1.3.0", "action_type": "write", "read_or_write": "write", "risk_class": "high" }
      ],
      "tool_cost_by_risk": { "low": 0.002, "medium": 0.02, "high": 0.05 },

      "guardrails": {
        "injection_scan": { "name": "input_prompt_injection_scan", "version": "3.1", "evaluator": "injection_classifier_v3", "threshold": 0.75, "background_rate": 0.008, "catch_rate": 0.92 },
        "pii_scan": { "name": "output_pii_egress_scan", "version": "2.2", "evaluator": "dlp_scanner_v2", "threshold": 0.8, "rate": 0.006 },
        "toxicity_scan": { "name": "output_toxicity_check", "version": "1.5", "evaluator": "toxicity_classifier_v1", "threshold": 0.6, "rate": 0.001 },
        "approval_policy": { "name": "high_risk_action_approval", "version": "1.0", "evaluator": "policy_engine" }
      },

      "volume": { "base_daily": 90, "growth_per_day": 1.5, "weekend_dip_factor": 0.6, "jitter": 10 },
      "escalation_rate": { "normal": 0.09, "spike": 0.15 },

      "storylines": {
        "release_regression": { "enabled": false },
        "injection_cluster": {
          "enabled": true, "day_start": 15, "day_end": 16, "rate": 0.15,
          "incident_id": "INC-2026-1516", "severity": "Sev2",
          "detected_offset": { "days": 15, "hours": 9, "minutes": 0 },
          "resolved_offset": { "days": 16, "hours": 12, "minutes": 30 },
          "root_cause_category": "prompt_injection_policy_bypass",
          "detection_source": "guardrail_anomaly_monitor",
          "mitigation": "Added secondary human-review gate on chargeback_file and card_block tools for flagged sessions."
        },
        "rate_limit_spike": {
          "enabled": true, "day_start": 24, "day_end": 24,
          "volume_multiplier": 1.8, "rate_limit_prob": 0.20, "fallback_prob": 0.70,
          "incident_id": "INC-2026-2400", "severity": "Sev2",
          "detected_offset": { "days": 24, "hours": 8, "minutes": 15 },
          "resolved_offset": { "days": 24, "hours": 18, "minutes": 0 },
          "root_cause_category": "provider_rate_limit_cascade",
          "detection_source": "cost_and_latency_anomaly_monitor",
          "affected_workflows_note": "~20% of workflows on day 24",
          "mitigation": "Raised primary provider quota tier ahead of month-end statement-cycle traffic."
        }
      }
    }
  ]
